{
  "name": "agentflow",
  "version": "0.1.0",
  "private": true,
  "description": "Stateful orchestration for staged, multi-thread agent development workflows.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx packages/cli/src/index.ts",
    "mcp": "tsx packages/mcp-server/src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
